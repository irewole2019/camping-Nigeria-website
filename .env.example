# Copy to .env.local and fill in. Never commit real values.

# Resend — transactional email.
# If missing, forms fall back to opening a mailto: draft in the user's mail
# client (no server send).
RESEND_API_KEY=

# Upstash Redis — per-IP rate limiting on form submission routes.
# Both must be set in production. If either is missing, the rate limiter
# fails open (no throttle) so local dev works without an Upstash account.
# Get both from https://console.upstash.com/ → create a Redis database →
# "REST API" tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# SEO / search console
# Optional: verification token from Google Search Console.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Optional: ISO date used for sitemap <lastmod> timestamps.
NEXT_PUBLIC_SEO_LAST_MODIFIED=2026-04-23T00:00:00.000Z

# Gear rental quote tool
# Published Google Sheets CSV for the rentable items list (items tab, gid=0).
# The /gear-rental form fetches this on mount to render the equipment selector.
# If missing or unreachable, the form falls back to a free-text message field.
NEXT_PUBLIC_SHEETS_ITEMS_URL=

# Base Camp Kids registration recording
# Google Apps Script Web App URL that appends a row to a registrations sheet.
# When unset, registrations still send emails — the Sheet step is skipped and
# logged. See lib/event-records.ts for the row schema.
GOOGLE_SHEETS_REGISTRATION_WEBHOOK_URL=

# inference.sh — image generation (GPT Image 2 etc.) for marketing assets.
# Used by local scripts under tools/ to generate Base Camp Kids hero, banner,
# and souvenir images. Get from https://app.inference.sh → Settings → API Keys.
INFERENCE_SH_API_KEY=
